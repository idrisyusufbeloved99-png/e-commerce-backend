// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum OrderStatus {
  PROCESSING
  SHIPPING
  DELIVERED
  CANCELLED
}

enum ProductStatus {
  ACTIVE
  OUT_OF_STOCK
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  email     String     @unique
  password  String
  avatar    String?
  role      Role       @default(CUSTOMER)
  status    UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?
  orders  Order[]
  reviews Review[]
   wishlists Wishlist[]
   couponUsages CouponUsage[]

  @@map("users")
}

model Profile {
  id          String @id @default(cuid())
  fullName    String
  address     String
  phoneNumber String
  city        String?
  state       String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  emoji String?

  products Product[]


  @@map("categories")
}

model Product {
  id            String        @id @default(cuid())
  name          String        @unique   
  description   String?
  unitPrice     Decimal       @db.Decimal(10, 2)
  originalPrice Decimal?      @db.Decimal(10, 2)
  stock         Int           @default(0)
  status        ProductStatus @default(ACTIVE)
  badge         String?
  hot           Boolean
  homeFeature   Boolean       @default(false)
  imageUrl      String?
  images        String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]
  reviews    Review[]
   wishlists Wishlist[]

  @@map("products")
}

model Review {
  id      String  @id @default(cuid())
  rating  Int      // 1-5
  comment String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId]) // one review per user per product
  @@map("reviews")
}

model Order {
  id       String      @id @default(cuid())
  status   OrderStatus @default(PROCESSING)
  total    Decimal     @db.Decimal(10, 2)
  shipping Decimal     @default(0) @db.Decimal(10, 2)
  tax      Decimal     @default(0) @db.Decimal(10, 2)

  // shipping snapshot — kept even if user later edits their Profile
  fullName    String
  email       String
  phoneNumber String
  address     String
  city        String
  state       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id       String  @id @default(cuid())
  quantity Int
  price    Decimal @db.Decimal(10, 2) // price snapshot at time of purchase

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}


model Wishlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId]) // can't wishlist the same product twice
  @@map("wishlists")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

model Coupon {
  id               String       @id @default(cuid())
  code             String       @unique
  description      String?
  discountType     DiscountType @default(PERCENTAGE)
  discountValue    Decimal      @db.Decimal(10, 2)
  minOrderSubtotal Decimal?     @db.Decimal(10, 2)
  maxUses          Int          @default(1)
  usedCount        Int          @default(0)
  startDate        DateTime?
  expiresAt        DateTime?
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())


  usages CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id       String   @id @default(cuid())
  usedAt   DateTime @default(now())

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_usages")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("subscribers")
}